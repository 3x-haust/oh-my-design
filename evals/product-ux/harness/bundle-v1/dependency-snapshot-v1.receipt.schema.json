{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"dependency-snapshot-v1.receipt.schema.json","type":"object","additionalProperties":false,"required":["schemaVersion","state","snapshotId","sealRunId","claimantNonce","claimPath","claimSha256","snapshotSha256"],"properties":{"schemaVersion":{"const":"dependency-snapshot-v1.receipt-v1"},"state":{"const":"PENDING_LAUNCHER"},"snapshotId":{"type":"string","pattern":"^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},"sealRunId":{"type":"string","minLength":1},"claimantNonce":{"type":"string","pattern":"^[0-9a-f]{64}$"},"claimPath":{"const":"claim.json"},"claimSha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"snapshotSha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}