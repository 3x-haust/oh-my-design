{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"dependency-seal-claim-conflict-v1.schema.json","type":"object","additionalProperties":false,"required":["schemaVersion","snapshotId","path","claimantRecordSha256","reason"],"properties":{"schemaVersion":{"const":"dependency-seal-claim-conflict-v1"},"snapshotId":{"type":"string","pattern":"^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},"path":{"type":"string","pattern":"^conflicts/[0-9a-f]{64}\\.json$"},"claimantRecordSha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"reason":{"enum":["EEXIST_CLAIM","EEXIST_VERDICT"]}}}