{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"seal-build-control-v1.schema.json","title":"Seal build control FD3 message","$comment":"Each message is framed as u32be UTF-8 JCS byte length followed by RFC 8785 JCS JSON. The maximum encoded JSON payload is 1048576 bytes; framing, UTF-8, JCS canonicality, ordering, and EOF are enforced by seal-protocol.ts.","type":"object","additionalProperties":false,"required":["schemaVersion","sealRunId","channelNonce","sequence","type"],"properties":{"schemaVersion":{"const":"seal-protocol-v1"},"sealRunId":{"type":"string","minLength":1},"channelNonce":{"type":"string","pattern":"^[0-9a-f]{64}$","description":"64-lower-hex SHA-256 channel nonce."},"sequence":{"type":"integer","minimum":0,"maximum":9007199254740991},"type":{"enum":["candidate-complete","exit-build","abort-build","exit-ack","shutdown"]},"ack":{"enum":["exit-build","abort-build"]}},"allOf":[{"if":{"properties":{"type":{"const":"exit-ack"}},"required":["type"]},"then":{"required":["ack"]},"else":{"not":{"required":["ack"]}}}]}