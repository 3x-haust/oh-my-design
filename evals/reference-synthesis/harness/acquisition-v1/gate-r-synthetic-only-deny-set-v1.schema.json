{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ohmydesign.dev/schemas/gate-r-synthetic-only-deny-set-v1.schema.json",
  "title": "Gate R synthetic capability raw-byte deny set v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordsSha256", "records"],
  "properties": {
    "schemaVersion": { "const": "gate-r-synthetic-only-deny-set-v1" },
    "recordsSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "records": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/record" } }
  },
  "$defs": {
    "record": {
      "description": "One synthetic capability's raw bytes and its independently checked identity.",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "mediaType", "capabilityKind"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "pattern": "^(?!.*(?:^|/)shared(?:/|$))(?!.*(?:^|/)live(?:/|$))(?!.*(?:^|/)(?:generated|deny-set|validation|vector)(?:[-_/.]|$))(?!.*\\.invalid$)[^/\\\\\u0000](?:[^/\\\\\u0000]*[^/\\\\\u0000])?$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "mediaType": { "type": "string", "minLength": 1 },
        "capabilityKind": { "enum": ["policy", "schema", "profile", "ca", "spki", "fixture-map", "server", "runtime", "private-key"] },
        "schemaId": { "type": "string", "minLength": 1, "not": { "pattern": "\\.invalid$" } }
      },
      "allOf": [{ "if": { "required": ["schemaId"] }, "then": { "properties": { "mediaType": { "const": "application/json" } } }]
    }
  }
}
